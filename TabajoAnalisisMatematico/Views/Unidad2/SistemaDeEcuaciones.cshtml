@{
    Layout = null;
    ViewData["Title"] = "Sistema de Ecuaciones";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    .app-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 20px;
        padding: 20px;
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    .content-area {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 20px;
    }

    .graph-container {
        min-height: 400px;
        width: 100%;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        background-color: #ffffff;
    }

    #ggb-element {
        width: 100%;
        height: 100%;
    }
</style>

<div class="app-container">

    <div class="card p-3 shadow-sm border-0">
        <div class="mb-3 d-flex gap-2">
            <a class="btn btn-dark btn-sm" href="/Home/Index">Unidad 1</a>
            <a class="btn btn-dark btn-sm" href="#">Unidad 2</a>
        </div>
        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <a class="nav-link text-muted" href="#">Gauss Jordan</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active text-dark fw-bold" href="#">Gauss Seidel</a>
            </li>
        </ul>
    </div>
</div>

