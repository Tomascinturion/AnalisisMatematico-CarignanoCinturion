@model TabajoAnalisisMatematico.Models.GaussSeidelModel
@{
    Layout = null;
    ViewData["Title"] = "GaussSeidel";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
<style>
    /* La misma grilla de la Unidad 1 */
    .app-container {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 20px;
        padding: 20px;
        background-color: #f8f9fa;
        min-height: 100vh;
    }

    /* Nota: Agrandé un poco la primera columna (de 320px a 400px) para que entren más cuadraditos de la matriz sin romperse */
    .content-area {
        display: grid;
        grid-template-columns: 400px 1fr;
        gap: 20px;
    }

    /* Estilos de la cuadrilla de Gauss */
    .matrix-input {
        width: 55px;
        height: 38px;
        text-align: center;
        border: 1px solid #dee2e6;
        border-radius: 4px;
        outline: none;
        transition: 0.2s;
    }

        .matrix-input:focus {
            border-color: #0d6efd;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }

    .matrix-row {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 8px;
        justify-content: center;
    }

    .equals-sign {
        font-weight: bold;
        color: #6c757d;
        margin: 0 2px;
    }

    .matrix-wrapper {
        overflow-x: auto;
        padding-bottom: 10px;
    }
    /* Por si hacen matrices muy grandes */
</style>

<div class="content-area">
    <div class="card p-3 shadow-sm border-0">
        <div class="mb-3 d-flex gap-2">
            <a class="btn btn-dark btn-sm" href="/Home/Index">Unidad 1</a>
            <a class="btn btn-dark btn-sm" href="#">Unidad 2</a>
        </div>
        <ul class="nav nav-tabs mb-3 flex-column border-0">
            <li class="nav-item">
                <a class="nav-link text-muted" href="/GaussJordan/GJ">Gauss Jordan</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active text-dark fw-bold border-bottom" href="#">Gauss Seidel</a>
            </li>
        </ul>
    </div>

    <div class="card p-4 shadow-sm border-0">
        <h3 class="text-secondary mb-4" style="font-weight: 300;">Gauss Seidel</h3>

        <form method="post" action="/GaussSeidel/GS">
            <div class="mb-4" style="max-width: 200px;">
                <label class="form-label text-muted">Dimensiones:</label>
                <input type="number" class="form-control" id="input-dimension" name="Dimension" value="3" min="2" max="10">
            </div>

            <div id="matriz-container" class="mb-4"></div>

            <button type="submit" class="btn btn-primary px-4 py-2" style="background-color: #5c7cfa; border: none;">Calcular</button>
        </form>

        @if (Model?.Resultado != null)
        {
            <div class="mt-5">
                <h3 class="text-secondary mb-4" style="font-weight: 300;">Solución</h3>

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">

                        <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4 mx-auto" style="max-width: 300px;">
                            <span class="fw-bold text-muted">
                                <i class="bi bi-arrow-repeat me-1"></i> Iteraciones realizadas:
                            </span>
                            <span class="badge rounded-pill bg-primary fs-6 px-3">@Model.Resultado.Iteraciones</span>
                        </div>

                        <div id="solucion-container">
                            <div class="matrix-wrapper d-flex justify-content-center">
                                <div>
                                    @{
                                        // Tu lógica para el tamaño de la matriz
                                        int tamaño = Model.Resultado.Resultado.Length;
                                    }

                                    @for (int i = 0; i < tamaño; i++)
                                    {
                                        <div class="matrix-row">
                                            @for (int j = 0; j < tamaño; j++)
                                            {
                                                string valorIdentidad = (i == j) ? "1" : "0";
                                                <input type="text" class="matrix-input bg-light text-muted" value="@valorIdentidad" readonly style="pointer-events: none;">
                                            }

                                            <span class="equals-sign">=</span>

                                            <input type="text" class="matrix-input bg-light text-primary fw-bold" value="@Model.Resultado.Resultado[i].ToString("F4")" readonly style="width: 80px; pointer-events: none;">
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        const inputDimension = document.getElementById('input-dimension');
        const matrizContainer = document.getElementById('matriz-container');

        // MAGIA: Traemos la matriz desde C# y la convertimos a un objeto que JavaScript entienda
        const matrizGuardada = @Html.Raw(Model?.Matriz != null ? Json.Serialize(Model.Matriz) : "null");

        // Variable para saber si estamos cargando la página después de tocar "Calcular"
        let esCargaPost = matrizGuardada !== null;

        // Función que dibuja la grilla
        function generarMatriz(n) {
            matrizContainer.innerHTML = '';

            for (let i = 0; i < n; i++) {
                const row = document.createElement('div');
                row.className = 'matrix-row';

                // Variables (A)
                for (let j = 0; j < n; j++) {
                    const input = document.createElement('input');
                    input.type = 'text';
                    input.step = 'any';
                    input.className = 'matrix-input';
                    input.name = `Matriz[${i}][${j}]`;
                    input.required = true;

                    // Si recargamos la página y hay datos, los volvemos a escribir en la cajita
                    if (esCargaPost && matrizGuardada[i] && matrizGuardada[i][j] !== undefined) {
                        input.value = matrizGuardada[i][j];
                    }

                    row.appendChild(input);
                }

                // Signo Igual
                const equals = document.createElement('span');
                equals.className = 'equals-sign';
                equals.innerText = '=';
                row.appendChild(equals);

                // Término Independiente (B)
                const inputIndependiente = document.createElement('input');
                inputIndependiente.type = 'text';
                inputIndependiente.step = 'any';
                inputIndependiente.className = 'matrix-input bg-light';
                inputIndependiente.name = `Matriz[${i}][${n}]`;
                inputIndependiente.required = true;

                // Si recargamos la página y hay datos, ponemos el término independiente
                if (esCargaPost && matrizGuardada[i] && matrizGuardada[i][n] !== undefined) {
                    inputIndependiente.value = matrizGuardada[i][n];
                }

                row.appendChild(inputIndependiente);
                matrizContainer.appendChild(row);
            }
        }

        // 1. Dibujamos la matriz inicial (con o sin memoria)
        generarMatriz(parseInt(inputDimension.value));

        // 2. Si el usuario cambia el tamaño a mano, redibujamos
        inputDimension.addEventListener('input', function(e) {
            let dim = parseInt(e.target.value);
            if (dim >= 2 && dim <= 10) {
                // Apagamos la memoria, porque si cambia a una de 4x4 queremos que arranque limpia
                esCargaPost = false;
                generarMatriz(dim);
            }
        });
    });
</script>
