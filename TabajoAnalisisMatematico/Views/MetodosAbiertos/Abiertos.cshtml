@model TabajoAnalisisMatematico.Models.MetodosCerradoAbierto

@{
    Layout = null;
    ViewData["Title"] = "Métodos Abiertos";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    .app-container { display: grid; grid-template-columns: 280px 1fr; gap: 20px; padding: 20px; background-color: #f8f9fa; min-height: 100vh; }
    .content-area { display: grid; grid-template-columns: 320px 1fr; gap: 20px; }
    .graph-container { min-height: 400px; width: 100%; border: 1px solid #dee2e6; border-radius: 0.375rem; background-color: #ffffff; }
    #ggb-element { width: 100%; height: 100%; }
</style>

<div class="app-container">
    
    <div class="card p-3 shadow-sm border-0">
        <div class="mb-3 d-flex gap-2">
            <button class="btn btn-dark btn-sm">Unidad 1</button>
        </div>

        <ul class="nav nav-tabs mb-3">
            <li class="nav-item">
                <a class="nav-link text-muted" href="/Home/Index">Métodos cerrados</a>
            </li>
            <li class="nav-item">
                <a class="nav-link active text-dark fw-bold" href="/MetodosAbiertos/Abiertos">Métodos abiertos</a>
            </li>
        </ul>

        <div class="nav flex-column nav-pills">
            <button class="nav-link active text-start mb-2" id="btn-tangente">Tangente</button>
            <button class="nav-link text-start text-dark bg-light border mb-2" id="btn-secante">Secante</button>
        </div>
    </div>

    <div class="content-area">
        
        <div class="card p-4 shadow-sm border-0">
            <form method="post" action="/MetodosAbiertos/Abiertos">
                <input type="hidden" name="MetodoElegido" id="hiddenMetodo" value="@(Model?.MetodoElegido ?? "tangente")" />

                <div class="mb-3">
                    <label class="form-label fw-bold mb-0">Función</label>
                    <input type="text" class="form-control bg-light" name="FuncionTexto" value="@Model?.FuncionTexto" required>
                    <small class="text-muted">Función a evaluar</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold mb-0">Xi</label>
                    <input type="number" step="any" class="form-control bg-light" name="Xi" value="@Model?.Xi" required>
                    <small class="text-muted">Punto inicial (X0)</small>
                </div>

                <div class="mb-3" id="div-xd">
                    <label class="form-label fw-bold mb-0">Xd</label>
                    <input type="number" step="any" class="form-control bg-light" name="Xd" value="@Model?.Xd">
                    <small class="text-muted">Punto auxiliar (X1)</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold mb-0">Iteraciones</label>
                    <input type="number" class="form-control bg-light" name="IteracionesMaximas" value="@(Model?.IteracionesMaximas > 0 ? Model.IteracionesMaximas : 100)" required>
                    <small class="text-muted">Número de iteraciones</small>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold mb-0">Tolerancia</label>
                    <input type="text" class="form-control bg-light" name="Tolerancia" value="@(Model?.Tolerancia > 0 ? Model.Tolerancia.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0.0001")" required>
                    <small class="text-muted">Tolerancia</small>
                </div>

                <button type="submit" class="btn btn-dark w-100 mt-3 py-2 fw-bold">CARGAR</button>
            </form>
        </div>

        <div class="d-flex flex-column gap-3">
            
            @if (Model?.Resultado == null)
            {
                <div class="alert alert-secondary text-center shadow-sm border-0">
                    <i class="bi bi-info-circle me-2"></i> Ingrese los parámetros y presione <strong>CARGAR</strong>.
                </div>
            }
            else if (!Model.Resultado.Exito)
            {
                <div class="alert alert-danger shadow-sm border-0">
                    <strong>Aviso:</strong> @Model.Resultado.Mensaje
                </div>
            }
            else
            {
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-dark text-white text-center py-3">
                        <h4 class="mb-0 font-monospace">Resultado</h4>
                    </div>
                    <div class="card-body px-4">
                        
                        <div class="d-flex justify-content-between align-items-end border-bottom pb-2 mb-3">
                            <span class="fw-bold text-muted">Iteraciones</span>
                            <span class="fs-5 fw-bold">@Model.Resultado.Iteraciones</span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-end border-bottom pb-2 mb-3">
                            <span class="fw-bold text-muted">Error relativo</span>
                            <span class="fs-5 fw-bold">@Model.Resultado.Error.ToString("F8")</span>
                        </div>
                        
                        <div class="d-flex justify-content-between align-items-end">
                            <span class="fw-bold text-muted">Raíz</span>
                            <span class="fs-4 fw-bold text-primary">@Model.Resultado.Raiz.ToString("F6")</span>
                        </div>

                    </div>
                </div>

                <div class="graph-container shadow-sm p-2 mt-2">
                    <div id="ggb-element"></div>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://www.geogebra.org/apps/deployggb.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        
    // --- 1. Lógica de los botones y visibilidad del campo Xd ---
    const btnTangente = document.getElementById('btn-tangente');
    const btnSecante = document.getElementById('btn-secante');
    const hiddenMetodo = document.getElementById('hiddenMetodo');
    const divXd = document.getElementById('div-xd');

    // Función auxiliar para configurar la vista según el método
    function setMetodo(metodo) {
    hiddenMetodo.value = metodo;
    if (metodo === "tangente") {
    btnTangente.classList.replace('bg-light', 'active');
    btnTangente.classList.replace('text-dark', 'text-white');
    btnSecante.classList.replace('active', 'bg-light');
    btnSecante.classList.replace('text-white', 'text-dark');
    divXd.style.display = 'none'; // Ocultar Xd
    } else {
    btnSecante.classList.replace('bg-light', 'active');
    btnSecante.classList.replace('text-dark', 'text-white');
    btnTangente.classList.replace('active', 'bg-light');
    btnTangente.classList.replace('text-white', 'text-dark');
    divXd.style.display = 'block'; // Mostrar Xd
    }
    }

    // Ejecutar estado inicial
    setMetodo(hiddenMetodo.value);

    if (btnTangente && btnSecante) {
    btnTangente.addEventListener('click', () => setMetodo("tangente"));
    btnSecante.addEventListener('click', () => setMetodo("secante"));
    }

    // --- 2. Lógica de GeoGebra (Para métodos abiertos) ---
    @if (Model?.Resultado?.Exito == true)
    {
        <text>
            const ggbContainer = document.getElementById('ggb-element');
            
            if (ggbContainer) {
            const funcionStr = '@Html.Raw(Model.FuncionTexto)';
            const raizX = @Model.Resultado.Raiz.ToString(System.Globalization.CultureInfo.InvariantCulture);

            const params = {
            "appName": "graphing",
            "width": ggbContainer.parentElement.clientWidth || 600,
            "height": 450,
            "showToolBar": false,
            "showAlgebraInput": false,
            "showMenuBar": false,
            "allowStyleBar": false,
            "enableRightClick": false,
            "useBrowserForJS": true,
            "appletOnLoad": function(ggbApi) {
            try {
            // A. Dibujar la Función f(x)
            ggbApi.evalCommand('f(x) = ' + funcionStr);
            ggbApi.setColor('f', 13, 110, 253);
            ggbApi.setLineThickness('f', 3);

            // B. Dibujar la Raíz
            ggbApi.evalCommand('Raiz = (' + raizX + ', 0)');
            ggbApi.setColor('Raiz', 220, 53, 69);
            ggbApi.setPointSize('Raiz', 5);
            ggbApi.showLabel('Raiz', false);

            // C. Zoom enfocado en la raíz
            const xMin = parseFloat(raizX) - 5;
            const xMax = parseFloat(raizX) + 5;
            ggbApi.setCoordSystem(xMin, xMax, -10, 10);
                            
            } catch (error) {
            console.error("Error en GeoGebra: ", error);
            }
            }
            };

            const applet = new GGBApplet(params, true);
            applet.inject('ggb-element');
            }
        </text>
    }
    });
</script>